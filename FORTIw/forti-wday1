!Config Static IP Address for FORTINET 80E ( Line 410-435 Paste on FORTINET 80E )
config system interface
 edit wan1
  set mode static
  set ip 200.0.0.12 255.255.255.0 
  set allowaccess ping https ssh telnet
  set role wan
  set alias "INTERNET"
  set status up
  next
 edit port1
  set mode static
  set ip 10.12.12.1 255.255.255.0
  set allowaccess ping https ssh telnet http
  set role lan
  set alias "INTERNAL"
  set status up
  next
edit loopback1
  set vdom root
  set mode static
  set ip 12.0.0.1 255.255.255.255
  set allowaccess ping
  set type loopback
  set status up
 end
end

